---
import '../styles/global.css';

const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | MAGSERV</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-white text-slate-900 font-sans flex flex-col min-h-screen">
    
    <header class="fixed w-full bg-white/95 backdrop-blur-md shadow-sm z-50 border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 h-20 flex justify-between items-center">
           <a href="/" class="shrink-0 flex items-center">
                <img src="/img/magservLogo.png" alt="Logotipo MAGSERV" class="h-14 w-auto" />
            </a>
            
            <nav class="hidden md:flex space-x-8 font-semibold text-[#0a2540] items-center">
                <a href="/" class="hover:text-blue-600 transition">Início</a>
                <a href="/servicos/eletrica" class="hover:text-blue-600 transition">Serviços</a>
                <a href="/parceiros" class="hover:text-blue-600 transition">Clientes Parceiros</a>
                <a href="#contato" class="bg-[#0a2540] text-white px-5 py-2 rounded hover:bg-blue-900 transition">Contato</a>
            </nav>

            <button id="mobile-menu-btn" class="md:hidden text-[#0a2540] focus:outline-none p-2" aria-label="Abrir menu">
                <i class="bi bi-list text-3xl"></i>
            </button>
        </div>

        <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-gray-100 shadow-xl absolute w-full">
            <nav class="flex flex-col px-6 pt-2 pb-8 space-y-2 font-semibold text-[#0a2540]">
                <a href="/" class="hover:text-blue-600 transition block py-3 border-b border-gray-50">Início</a>
                <a href="/servicos/eletrica" class="hover:text-blue-600 transition block py-3 border-b border-gray-50">Serviços</a>
                <a href="/parceiros" class="hover:text-blue-600 transition block py-3 border-b border-gray-50">Clientes Parceiros</a>
                <a href="#contato" class="bg-[#0a2540] text-white px-5 py-3 rounded hover:bg-blue-900 transition text-center mt-6 block">Fale Connosco</a>
            </nav>
        </div>
    </header>

    <main class="pt-20 grow">
        <slot /> 
    </main>

    <footer class="bg-[#0a2540] text-white py-12 mt-auto">
        <div class="max-w-7xl mx-auto px-4 grid md:grid-cols-3 gap-8 border-b border-white/10 pb-8">
            <div>
                <img src="/img/magservLogoBranco.png" alt="Logotipo MAGSERV Branco" class="h-10 w-auto">
                <p class="text-gray-400 mt-4 text-sm">Soluções integradas em construção civil e manutenção predial.</p>
            </div>
            <div>
                <h4 class="font-bold mb-4">Serviços</h4>
                <ul class="text-gray-400 text-sm space-y-2">
                    <li><a href="/servicos/construcao-civil" class="hover:text-white">Construção Civil</a></li>
                    <li><a href="/servicos/eletrica" class="hover:text-white">Elétrica Predial</a></li>
                    <li><a href="/servicos/hidraulica" class="hover:text-white">Hidráulica</a></li>
                    <li><a href="/servicos/contratos-manutencao" class="hover:text-white">Manutenção Predial</a></li>
                </ul>
            </div>
            <div>
                <h4 class="font-bold mb-4">Contato</h4>
                <p class="text-gray-400 text-sm"><i class="bi bi-envelope-fill mr-2"></i>comercial@manuserv.com.br</p>
                <p class="text-gray-400 text-sm mt-2"><i class="bi bi-telephone-fill mr-2"></i>(41) 99111-0000</p>
            </div>
        </div>
        <div class="text-center mt-8 text-gray-500 text-xs">
            © 2026 ManuServ. Todos os direitos reservados.
        </div>
    </footer>
</body>
</html>