---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import bgIndex from '../assets/index-bg.jpg';
---

<Layout title="Home" description="Especialistas em engenharia e manutenção predial.">
    
    <section class="relative h-[85vh] flex items-center bg-[#0a2540]">
        <div class="absolute inset-0 opacity-20">
            <Image 
                src={bgIndex} 
                alt="Instalações Elétricas" 
                class="w-full h-full object-cover object-center" 
                quality="high"
            />
        </div>
        
        <div class="max-w-7xl mx-auto px-4 relative z-10 text-white w-full">
            <span class="border border-white/30 text-blue-400 px-4 py-1 rounded-full text-sm font-semibold tracking-wider uppercase mb-6 inline-block">
                Fazer. Inovar. Solucionar.
            </span>
            <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6 max-w-4xl">
                Excelência em Construção Civil e Manutenção Predial
            </h1>
            <p class="text-xl text-gray-300 max-w-2xl mb-10">
                Obras corporativas, instalações elétricas, hidráulica e contratos de manutenção predial com rigor técnico e foco na segurança do seu patrimônio.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="#servicos" class="bg-blue-600 text-white px-8 py-4 rounded font-bold hover:bg-blue-700 transition text-center shadow-lg">
                    Conheça Nossos Serviços
                </a>
                <a href="/parceiros" class="border border-white text-white px-8 py-4 rounded font-bold hover:bg-white/10 transition text-center">
                    Área de Clientes Parceiros
                </a>
            </div>
        </div>
    </section>

    <section id="servicos" class="py-24 bg-gray-50 border-t border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="text-center max-w-3xl mx-auto mb-16">
                <span class="text-[#0a2540] font-bold tracking-wider uppercase text-sm block mb-2">Nossa Expertise</span>
                <h2 class="text-3xl md:text-4xl font-bold text-[#0a2540] mb-6">Soluções Completas para o seu Negócio</h2>
                <div class="h-1 w-24 bg-blue-600 mx-auto rounded"></div>
                <p class="text-gray-600 mt-6 text-lg">
                    Atuamos com equipes multiespecializadas para garantir a segurança, eficiência e valorização do seu patrimônio físico.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                
                <div class="bg-white p-8 rounded-xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-blue-100 transition-all duration-300 group flex flex-col h-full">
                    <div class="w-14 h-14 bg-[#0a2540]/5 text-[#0a2540] rounded-lg flex items-center justify-center mb-6 group-hover:bg-[#0a2540] group-hover:text-white transition-colors duration-300">
                        <i class="bi bi-building-fill text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-[#0a2540] mb-3">Construção Civil</h3>
                    <p class="text-gray-600 text-sm mb-6 grow">
                        Execução de obras corporativas, reformas estruturais, adequações de layout e ampliações com rigoroso cumprimento de cronograma.
                    </p>
                    <a href="/servicos/construcao-civil" class="text-blue-600 font-bold text-sm group-hover:text-blue-800 transition-colors flex items-center mt-auto">
                        Detalhes do serviço <i class="bi bi-arrow-right ml-2 transform group-hover:translate-x-1 transition-transform text-lg"></i>
                    </a>
                </div>

                <div class="bg-white p-8 rounded-xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-blue-100 transition-all duration-300 group flex flex-col h-full">
                    <div class="w-14 h-14 bg-[#0a2540]/5 text-[#0a2540] rounded-lg flex items-center justify-center mb-6 group-hover:bg-[#0a2540] group-hover:text-white transition-colors duration-300">
                        <i class="bi bi-lightning-charge-fill text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-[#0a2540] mb-3">Instalações Elétricas</h3>
                    <p class="text-gray-600 text-sm mb-6 grow">
                        Projetos, modernização de quadros de distribuição, retrofit predial, laudos SPDA e adequações completas à norma.
                    </p>
                    <a href="/servicos/eletrica" class="text-blue-600 font-bold text-sm group-hover:text-blue-800 transition-colors flex items-center mt-auto">
                        Detalhes do serviço <i class="bi bi-arrow-right ml-2 transform group-hover:translate-x-1 transition-transform text-lg"></i>
                    </a>
                </div>

                <div class="bg-white p-8 rounded-xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-blue-100 transition-all duration-300 group flex flex-col h-full">
                    <div class="w-14 h-14 bg-[#0a2540]/5 text-[#0a2540] rounded-lg flex items-center justify-center mb-6 group-hover:bg-[#0a2540] group-hover:text-white transition-colors duration-300">
                        <i class="bi bi-wrench-adjustable text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-[#0a2540] mb-3">Sistemas Hidráulicos</h3>
                    <p class="text-gray-600 text-sm mb-6 grow">
                        Implantação e manutenção de redes de água, esgoto, ar comprimido e sistemas integrados de combate a incêndio.
                    </p>
                    <a href="/servicos/hidraulica" class="text-blue-600 font-bold text-sm group-hover:text-blue-800 transition-colors flex items-center mt-auto">
                        Detalhes do serviço <i class="bi bi-arrow-right ml-2 transform group-hover:translate-x-1 transition-transform text-lg"></i>
                    </a>
                </div>

                <div class="bg-white p-8 rounded-xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-blue-100 transition-all duration-300 group flex flex-col h-full bg-linear-to-b from-white to-blue-50/50">
                    <div class="w-14 h-14 bg-[#0a2540]/5 text-[#0a2540] rounded-lg flex items-center justify-center mb-6 group-hover:bg-[#0a2540] group-hover:text-white transition-colors duration-300">
                        <i class="bi bi-shield-fill-check text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-[#0a2540] mb-3">Contratos de Manutenção</h3>
                    <p class="text-gray-600 text-sm mb-6 grow">
                        Gestão contínua de facilities com foco preventivo e corretivo. Terceirização técnica para garantir a valorização do seu ativo.
                    </p>
                    <a href="/servicos/contratos-manutencao" class="text-blue-600 font-bold text-sm group-hover:text-blue-800 transition-colors flex items-center mt-auto">
                        Conheça os planos <i class="bi bi-arrow-right ml-2 transform group-hover:translate-x-1 transition-transform text-lg"></i>
                    </a>
                </div>

            </div>
        </div>
    </section>
</Layout>